# Motor de Reservas — engine.transporteexecutivo.com (porta 8000)
# EasyPanel: Dockerfile (padrao) | Dominio destino HTTP 8000

APP_NAME=Motor de Reservas Nexus Transfer
APP_ENV=production
DEBUG=false

SECRET_KEY=change-me-minimum-32-characters-long
BASE_URL=https://engine.transporteexecutivo.com
ALLOWED_HOSTS=engine.transporteexecutivo.com,transporteexecutivo.com,www.transporteexecutivo.com
HEALTHCHECK_HOST=engine.transporteexecutivo.com

DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxx.supabase.co:5432/postgres

REDIS_ENABLED=false

JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

CSRF_SECRET_KEY=change-me-csrf-secret-min-32-chars

MASTER_API_BASE_URL=https://api.transporteexecutivo.com
MASTER_API_KEY=
MASTER_API_TIMEOUT=30

GATEWAY_API_BASE_URL=https://api.transporteexecutivo.com
GATEWAY_MOCK_FALLBACK=false

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

CORS_ORIGINS=https://engine.transporteexecutivo.com,https://transporteexecutivo.com,https://www.transporteexecutivo.com

RATE_LIMIT_PER_MINUTE=120
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
