# Application
APP_NAME=Motor de Reservas Nexus Transfer
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-64-char-random-string-in-production
BASE_URL=https://engine.transporteexecutivo.com
ALLOWED_HOSTS=engine.transporteexecutivo.com,localhost,127.0.0.1

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Redis (optional cache)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CSRF
CSRF_SECRET_KEY=change-me-csrf-secret

# Master System API (desacoplado)
MASTER_API_BASE_URL=https://api.transporteexecutivo.com
MASTER_API_KEY=your-master-api-key
MASTER_API_TIMEOUT=30

# Gateway Master (porta 8770) — branding, cotação, reserva
GATEWAY_API_BASE_URL=http://127.0.0.1:8770
GATEWAY_API_KEY=
GATEWAY_API_TIMEOUT=30
GATEWAY_MOCK_FALLBACK=false

# Supabase Master — frota por cidade (RPC motor_list_vehicles_by_city)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Payment gateways (preparado)
MERCADOPAGO_ACCESS_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PIX_PROVIDER_KEY=

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@transporteexecutivo.com

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Security headers
CORS_ORIGINS=https://engine.transporteexecutivo.com,http://localhost:8000
