# Centro Operacional Master — api.transporteexecutivo.com (porta 8770)
# EasyPanel: Dockerfile ou Dockerfile.sistema | Dominio destino HTTP 8770
# OBRIGATORIO no app api.* — faz o container subir o Sistema, nao o Motor:

NEXUS_DEPLOY_TARGET=sistema

APP_ENV=production

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

NEXUS_BIND_HOST=0.0.0.0
INTEGRACAO_GATEWAY_HOST=0.0.0.0

GATEWAY_MOCK_FALLBACK=false

# Integracao website (quando ativar)
WEBHOOK_OUTBOUND_URL=
GATEWAY_WEBHOOK_SECRET=
INTEGRACAO_WEBHOOK_ENABLED=false
INTEGRACAO_WEBHOOK_URL=
INTEGRACAO_WEBHOOK_SECRET=
